    "version": "0.2.0",
    "configurations": [

        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Amex Debug",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\BudgetScript.py",
            "console": "integratedTerminal",
            "args": [
                "-p",
                "C:\\Users\\sophi\\Downloads\\activity.xlsx",
                "-t",
                "amex"
            ],
        },
        {
            "name": "Bank Debug",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\BudgetScript.py",
            "console": "integratedTerminal",
            "args": [
                "-p",
                "C:\\Users\\sophi\\Downloads\\transactions.csv",
                "-t",
                "bank"
            ],
        },
        {
            "name": "Python Debugger: Predictor With Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\Predictor.py",
            "console": "integratedTerminal",
            "args": [
                "--filepath",
                "C:\\Users\\sophi\\OneDrive\\Documents\\BigAssBudgetData.xlsx"
            ],
            "guiEventLoop": "qt6"
        }
    ]
}